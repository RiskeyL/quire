{
  "name": "@riskeyl/quire",
  "version": "0.1.0",
  "description": "Convert Markdown and MDX documentation, including Mintlify components, into brand-consistent PDF and Word files from a single theme file.",
  "keywords": [
    "markdown",
    "mdx",
    "pdf",
    "docx",
    "word",
    "documentation",
    "pandoc",
    "pagedjs",
    "mintlify"
  ],
  "homepage": "https://github.com/RiskeyL/quire#readme",
  "bugs": "https://github.com/RiskeyL/quire/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RiskeyL/quire.git"
  },
  "license": "MIT",
  "author": "RiskeyL",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "quire": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "build:designer": "tsx scripts/build-designer.ts",
    "prepare": "npm run build && npm run build:designer"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "mermaid": "^11.15.0",
    "pagedjs-cli": "^0.4.3",
    "puppeteer": "^20.9.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tslib": "^2.8.1",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.1",
    "esbuild": "0.28.0",
    "pagedjs": "0.4.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
